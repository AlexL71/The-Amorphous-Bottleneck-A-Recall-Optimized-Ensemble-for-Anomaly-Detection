# ===================================================
# 1. Data (Proprietary, not redistributable)
# ===================================================
# Ignore the large dataset folders
/data/train/
/data/val/
/data/test/
/data/original data/

# Explicitly keep the small sample data
!/data/sample/

# ===================================================
# 2. Documents & Temporary Work
# ===================================================
/paper/
/tmp/

# ===================================================
# 3. Model Weights & Training Logs
# ===================================================
/models/
/weights/
/work_dirs/
*.pth
*.pt
*.ckpt

# ===================================================
# 4. Large Intermediate Files
# ===================================================
# Keep outputs/ JSONs (they are the experiment results).
# Note: Git cannot ignore files based on file size. 
# If you generate massive CSVs or logs you want to ignore, 
# list their specific extensions or folders here:
# /outputs/massive_logs/
# *.large_csv

# ===================================================
# 5. Python & Jupyter Environment
# ===================================================
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/
.pytest_cache/
.env
venv/
env/

# ===================================================
# 6. OS Generated Files
# ===================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db